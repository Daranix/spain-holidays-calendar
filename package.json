{
  "name": "calendario-web",
  "version": "1.0.0",
  "scripts": {
    "start": "node dist/server/server.mjs",
    "build": "ng build --configuration production && capacitor sync",
    "build:dev": "ng build --configuration development",
    "watch": "npm run build:dev -- --configuration development --watch",
    "dev": "ng serve --host 0.0.0.0",
    "dev:ssr:watch": "concurrently \"npm run watch\" \"nodemon --watch dist/server dist/server/server.mjs\"",
    "android:dev": "npm run build:dev && capacitor sync android && capacitor run android --external && npm start",
    "biome": "biome",
    "capacitor": "capacitor",
    "ng": "ng",
    "generate-assets": "npx @capacitor/assets generate"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.3",
    "@angular/common": "^21.2.3",
    "@angular/compiler": "^21.2.3",
    "@angular/core": "^21.2.3",
    "@angular/forms": "^21.2.3",
    "@angular/platform-browser": "^21.2.3",
    "@angular/platform-browser-dynamic": "^21.2.3",
    "@angular/platform-server": "^21.2.3",
    "@angular/router": "^21.2.3",
    "@angular/ssr": "^21.2.2",
    "@capacitor/android": "^8.0.0",
    "@capacitor/angular": "^2.0.3",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "linkedom": "^0.18.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "valibot": "^0.29.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.3",
    "@biomejs/biome": "1.6.4",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.4",
    "@types/node": "^20.12.5",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "jasmine-core": "~5.1.2",
    "karma": "~6.4.3",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.9.3"
  }
}
